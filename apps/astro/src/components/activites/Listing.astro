---
import PortableText, { type PortableTextValue } from '@/src/components/ui/portable-text'
import { getLangFromPath, type Language } from '@/global/languages'
import CategoryBlock, { CategoryBlockQuery, type CategoryBlockProps } from '../ui/CategoryBlock.astro'
import SearchBar from '../ui/SearchBar.astro'
import Button from '@/src/components/ui/Button'

type Props = {
  heading: PortableTextValue
  paragraph: PortableTextValue
  listing: CategoryBlockProps[]
}
export type ListingProps = Props

const lang = getLangFromPath(Astro.url.pathname) as Language

const translations = {
  pl: {
    pathPrefix: '/pl/integracje',
    filterPath: 'filtr',
    categories: 'Kategorie',
    all: 'Wszystkie',
    placeholder: 'Wyszukaj integrację np. sabotażysta',
    chooseCategory: 'lub wybierz interesującą Cię kategorię',
    showMore: 'Pokaż więcej',
    showLess: 'Pokaż mniej',
  },
  en: {
    pathPrefix: '/en/activities',
    filterPath: 'filter',
    categories: 'Categories',
    all: 'All',
    placeholder: 'Search for activities',
    chooseCategory: 'or choose a category, that you are interested in',
    showMore: 'Show more',
    showLess: 'Show less',
  },
}

const t = translations[lang]

export const Listing_Query = `
    "listing": *[_type == 'ActivitiesCategory_Collection'
      && language == $language
      && count(activities) > 0
    ] | order(orderRank asc) {
        ${CategoryBlockQuery}
    },
`

const { listing, heading, paragraph } = Astro.props
---

<section class="Listing max-width" data-filter-path={t.filterPath}>
  <header class="header">
    <PortableText value={heading} class="heading" heading="h1" />
    <PortableText value={paragraph} class="paragraph" />
    <SearchBar value={Astro.url.searchParams.get('search') || ''} placeholder={t.placeholder} />
    <p class="choose-category">{t.chooseCategory}</p>
  </header>
  <div class:list={['list-container', { 'is-peek-initial': listing.length > 8 }]} data-peek={listing.length > 8 ? 'true' : undefined}>
    <div class="list">
      {
        listing.map((item, index) => (
          <CategoryBlock
            {...item}
            imageConfig={{
              sizes:
                '(max-width: 27.4375rem) 74px, (max-width: 37.4375rem) 45vw, (max-width: 52.4375rem) 38vw, (max-width: 68.0625rem) 29vw, (max-width: 85.375rem) 23vw, 312px',
              loading: 'eager',
              fetchPriority: index === 0 ? 'high' : 'auto',
            }}
          />
        ))
      }
    </div>
  </div>
  <div class="show-more-wrapper" data-peek={listing.length > 8 ? 'true' : undefined}>
    <Button
      theme="secondary"
      shade="dark"
      className="show-more-toggle"
      data-show-more={t.showMore}
      data-show-less={t.showLess}
      aria-expanded="false"
    >
      {t.showMore}
    </Button>
  </div>
</section>

<style lang="scss">
  .Listing {
    padding: clamp(3.75rem, calc(5.75vw / 0.48), 5.75rem) 0 3rem;

    .header {
      max-width: 34.5rem;
      text-align: center;
      margin: 0 auto clamp(2rem, calc(3vw / 0.48), 3rem);
      .heading {
        margin-bottom: clamp(0.75rem, calc(1vw / 0.48), 1rem);
        font-size: var(--typography-heading-l, 2rem);
      }

      .paragraph {
        font-size: var(--typography-body-xl, 1.125rem);
        line-height: 1.5;
        margin-bottom: clamp(1.5rem, calc(2vw / 0.48), 2rem);
      }

      .choose-category {
        font-size: var(--typography-body-l, 1rem);
      }
    }

    .list-container {
      position: relative;
      overflow: hidden;
      transition: max-height 600ms var(--easing);

      &.is-peek-initial:not([data-js-ready]) {
        max-height: 30rem;

        @media (max-width: 52.4375rem) {
          max-height: 28rem;
        }

        @media (max-width: 27.4375rem) {
          max-height: 50rem;
        }
      }

      &::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 10rem;
        background: linear-gradient(to bottom, transparent, var(--neutral-100, #faf5f3));
        pointer-events: all;
        opacity: 0;
        transition: opacity 400ms var(--easing);
        z-index: 1;
      }

      &[data-peek='true']::after {
        opacity: 1;
      }
    }

    .list {
      gap: 2rem 1rem;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
    }

    .show-more-wrapper {
      display: flex;
      justify-content: center;
      position: relative;
      z-index: 2;
      margin-top: clamp(1rem, calc(1.5vw / 0.48), 1.5rem);

      &[data-peek='true'] {
        margin-top: -2rem;
      }
    }

    @media (max-width: 68.0625rem) {
      .list {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 52.4375rem) {
      .list {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 27.4375rem) {
      .header {
        text-align: left;

        :global(.SearchBar) {
          margin-left: 0;
          margin-right: 0;
        }
      }
      .list {
        grid-template-columns: repeat(1, 1fr);
        justify-items: center;

        :global(.CategoryBlock) {
          display: grid;
          grid-template-columns: clamp(5rem, calc(5vw / 0.48), 6rem) 1fr;
          grid-template-rows: auto 1fr;
          gap: 0.625rem;
          max-width: 100%;
          position: relative;
          padding-right: 0.5rem;
          border-radius: 999px 64px 64px 999px;
          background-color: var(--neutral-100);
          :global(.wrapper) {
            grid-column: 1/2;
            grid-row: 1/3;
            align-self: start;
            margin-bottom: 0;
          }

          :global(.title) {
            grid-column: 2/3;
            grid-row: 1/2;
            align-self: center;

            :global(.text) {
              display: block;
              margin-right: 0;
              font-size: var(--typography-body-m, 0.875rem);
            }

            :global(.count) {
              position: absolute;
              bottom: 0.25rem;
              left: 3.375rem;
              transform: scale(0.8);
            }
          }

          :global(.description) {
            grid-column: 2/3;
            grid-row: 2/3;
          }
        }
      }
    }
  }
</style>

<script>
  const INITIAL_ROWS = 2
  const INITIAL_ROWS_SINGLE_COL = 4
  const ROWS_PER_EXPANSION = 4
  const PEEK_HEIGHT = 120

  const section = document.querySelector('.Listing') as HTMLElement | null
  if (section) {
    const container = section.querySelector('.list-container') as HTMLElement | null
    const listEl = container?.querySelector('.list') as HTMLElement | null
    const cards = listEl ? Array.from(listEl.querySelectorAll<HTMLElement>('.CategoryBlock')) : []
    const wrapper = section.querySelector('.show-more-wrapper') as HTMLElement | null
    const button = wrapper?.querySelector('.show-more-toggle') as HTMLButtonElement | null
    const buttonSpan = button?.querySelector('span') as HTMLSpanElement | null

    if (container && listEl && cards.length > 0 && button && buttonSpan && wrapper) {
      let visibleRows = INITIAL_ROWS

      const getColumns = () => {
        const cols = getComputedStyle(listEl).gridTemplateColumns.split(' ')
        return cols.length
      }

      const getInitialRows = (columns: number) =>
        columns === 1 ? INITIAL_ROWS_SINGLE_COL : INITIAL_ROWS

      const getRowHeight = (rowIndex: number, columns: number) => {
        const firstInRow = cards[rowIndex * columns]
        if (!firstInRow) return 0
        const style = getComputedStyle(listEl)
        const rowGap = parseFloat(style.rowGap) || 0
        return firstInRow.offsetHeight + (rowIndex > 0 ? rowGap : 0)
      }

      const getHeightForRows = (rowCount: number, columns: number) => {
        let height = 0
        for (let r = 0; r < rowCount; r++) {
          height += getRowHeight(r, columns)
        }
        return height
      }

      const updateVisibility = () => {
        const columns = getColumns()
        const initialRows = getInitialRows(columns)
        const totalCards = cards.length
        const totalRows = Math.ceil(totalCards / columns)
        const clampedRows = Math.min(visibleRows, totalRows)
        const allVisible = clampedRows >= totalRows
        const fitsInitial = totalRows <= initialRows

        if (fitsInitial) {
          wrapper.style.display = 'none'
          container.style.maxHeight = ''
          container.style.overflow = ''
          container.removeAttribute('data-peek')
          wrapper.removeAttribute('data-peek')
          return
        }

        wrapper.style.display = ''
        const visibleHeight = getHeightForRows(clampedRows, columns)

        if (allVisible) {
          container.style.maxHeight = ''
          container.style.overflow = ''
          container.removeAttribute('data-peek')
          wrapper.removeAttribute('data-peek')
          buttonSpan.textContent = button.getAttribute('data-show-less')
          button.setAttribute('aria-expanded', 'true')
        } else {
          const peekAmount = Math.min(PEEK_HEIGHT, getRowHeight(clampedRows, columns) * 0.6)
          container.style.maxHeight = `${visibleHeight + peekAmount}px`
          container.style.overflow = 'hidden'
          container.setAttribute('data-peek', 'true')
          wrapper.setAttribute('data-peek', 'true')
          buttonSpan.textContent = button.getAttribute('data-show-more')
          button.setAttribute('aria-expanded', 'false')
        }
      }

      button.addEventListener('click', () => {
        const columns = getColumns()
        const totalCards = cards.length
        const totalRows = Math.ceil(totalCards / columns)
        const allVisible = Math.min(visibleRows, totalRows) >= totalRows

        if (allVisible) {
          visibleRows = getInitialRows(columns)
          updateVisibility()
          section.scrollIntoView({ behavior: 'smooth', block: 'start' })
        } else {
          visibleRows = Math.min(visibleRows + ROWS_PER_EXPANSION, totalRows)
          updateVisibility()
        }
      })

      let resizing = false
      const observer = new ResizeObserver(() => {
        const columns = getColumns()
        const initialRows = getInitialRows(columns)
        if (visibleRows < initialRows) visibleRows = initialRows
        if (!resizing) {
          resizing = true
          container.style.transition = 'none'
        }
        updateVisibility()
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            container.style.transition = ''
            resizing = false
          })
        })
      })
      observer.observe(listEl)

      container.style.transition = 'none'
      visibleRows = getInitialRows(getColumns())
      updateVisibility()
      container.setAttribute('data-js-ready', '')
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          container.style.transition = ''
        })
      })
    }
  }
</script>
