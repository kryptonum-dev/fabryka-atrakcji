---
import PortableText, { type PortableTextValue } from '@/src/components/ui/portable-text'
import { getLangFromPath, type Language } from '@/global/languages'
import SearchBar from '../ui/SearchBar.astro'
import Dropdown from '../ui/Dropdown.astro'
import EventSpaceCard, { EventSpaceCardQuery } from '../ui/EventSpaceCard.astro'
import Pagination from '../ui/Pagination.astro'
import { ITEMS_PER_PAGE } from '@/src/templates/event-spaces/EventSpacesPage.astro'
import Button from '../ui/Button'
import SelectFilter from '../ui/SelectFilter.astro'

type LocationOption = {
  _id: string
  name: string
  count: number
  slug: string
}

type EventSpaceItem = {
  _id: string
  name: string
  slug: string
  previewImage?: any
  location: {
    name: string
    slug: string
  }
  address: {
    city: string
    street: string
    postalCode: string
    voivodeship: string
  }
  areaM2: number
  maxPeople: number
  pricing?: {
    pricingVisible?: boolean
    displayMode?: 'quoteOnly' | 'fromPrice'
    fromPrice?: number
    priceLabel?: string
  }
}

type Props = {
  heading: PortableTextValue
  paragraph: PortableTextValue
  totalItems: number
  listing: EventSpaceItem[]
  currentPage: number
  locations: LocationOption[]
  areaFilterOptions: {
    min: number
    max?: number
  }[]
  areaFilterSource: {
    areaM2: number
  }[]
  capacityFilterSource: {
    maxPeople: number
  }[]
  capacityFilterOptions: {
    min: number
    max?: number
  }[]
  checklist: string[] | null
  escapeHintText?: string
  escapeHintCta?: string
}

export type ListingProps = Props

export const Listing_Query = (orderClause: string) => {
  const locationFilter = `(!defined($location) || location->slug.current == $location)`
  const areaFilter = `
    (!defined($minArea) || areaM2 >= $minArea)
    && (!defined($maxArea) || areaM2 <= $maxArea)
  `
  const capacityFilter = `
    (!defined($minCapacity) || maxPeople >= $minCapacity)
    && (!defined($maxCapacity) || maxPeople <= $maxCapacity)
  `
  const searchFilter = `(!defined($searchPattern) || name match $searchPattern)`

  const createBaseFilter = (
    includeFilters: {
      location?: boolean
      area?: boolean
      capacity?: boolean
    } = {
      location: true,
      area: true,
      capacity: true,
    }
  ) => `
    && language == $language
    && ${searchFilter}
    ${includeFilters.location ? `&& ${locationFilter}` : ''}
    ${includeFilters.area ? `&& ${areaFilter}` : ''}
    ${includeFilters.capacity ? `&& ${capacityFilter}` : ''}
  `

  return `
    "totalItems": count(*[_type == 'EventSpaces_Collection' ${createBaseFilter()}]),
    "locations": *[_type == 'Locations_Collection' && language == $language] {
      _id,
      name,
      "slug": slug.current,
      "count": count(*[_type == 'EventSpaces_Collection' ${createBaseFilter({
        location: false,
        area: true,
        capacity: true,
      })} && references(^._id)])
    },
    "areaFilterSource": *[_type == 'EventSpaces_Collection' ${createBaseFilter({
      location: true,
      area: false,
      capacity: true,
    })}] {
      areaM2
    },
    "capacityFilterSource": *[_type == 'EventSpaces_Collection' ${createBaseFilter({
      location: true,
      area: true,
      capacity: false,
    })}] {
      maxPeople
    },
    "listing": *[_type == 'EventSpaces_Collection' ${createBaseFilter()}] {
      ${EventSpaceCardQuery}
    } | order(${orderClause}) [$PAGINATION_BEFORE...$PAGINATION_AFTER],
  `
}

const {
  heading,
  paragraph,
  checklist,
  totalItems,
  listing,
  currentPage,
  locations,
  areaFilterOptions,
  areaFilterSource,
  capacityFilterSource,
  capacityFilterOptions,
  escapeHintText,
  escapeHintCta,
} = Astro.props as Props

const lang = getLangFromPath(Astro.url.pathname) as Language
const safeChecklist = checklist ?? []
const params = Astro.url.searchParams

const translations = {
  pl: {
    pathPrefix: '/pl/przestrzenie-eventowe',
    filterPath: 'filtr',
    pagePath: 'strona',
    placeholder: 'Wyszukaj przestrzeń eventową',
    filters: {
      location: 'Lokalizacja',
      capacity: 'Maks. liczba osób',
      area: 'Powierzchnia',
    },
    noResults: {
      heading: '<span>Nie znaleziono wyników dla</span> <strong>podanych filtrów</strong>',
      list: [
        'Sprawdź poprawność wprowadzonych danych',
        'Zmień kryteria wyszukiwania',
        'Lub znajdź interesujące Cię przestrzenie w widoku wszystkich obiektów',
      ],
      button: 'Wróć do wszystkich przestrzeni',
    },
    foundPrefix: 'Znaleziono',
    foundSingle: 'przestrzeń',
    foundFew: 'przestrzenie',
    foundMany: 'przestrzeni',
    filtersHeading: 'Filtry',
    apply: 'Zastosuj filtry',
    clear: 'Wyczyść filtry',
    filterButton: 'Filtruj',
  },
  en: {
    pathPrefix: '/en/event-spaces',
    filterPath: 'filter',
    pagePath: 'page',
    placeholder: 'Search event spaces',
    filters: {
      location: 'Location',
      capacity: 'Max people',
      area: 'Area',
    },
    noResults: {
      heading: '<span>No results found for</span> <strong>the given filters</strong>',
      list: [
        'Check the correctness of the data entered',
        'Change the search criteria',
        'Or find interesting venues in the full event spaces listing',
      ],
      button: 'Back to all event spaces',
    },
    foundPrefix: 'Found',
    foundSingle: 'event space',
    foundFew: 'event spaces',
    foundMany: 'event spaces',
    filtersHeading: 'Filters',
    apply: 'Apply filters',
    clear: 'Clear filters',
    filterButton: 'Filter',
  },
} as const

const t = translations[lang]

const normalizedAreaFilterOptions = (areaFilterOptions || []).filter(
  (option: { min: number; max?: number }) => option?.min
)
const normalizedCapacityFilterOptions = (capacityFilterOptions || []).filter(
  (option: { min: number; max?: number }) => option?.min
)

const areaRangeItems = normalizedAreaFilterOptions
  .map((option: { min: number; max?: number }) => ({
    name: option.max ? `${option.min}–${option.max} m2` : `${option.min}+ m2`,
    count: (areaFilterSource || []).filter((item: { areaM2: number }) => {
      if (!item?.areaM2) return false
      return option.max ? item.areaM2 >= option.min && item.areaM2 <= option.max : item.areaM2 >= option.min
    }).length,
    isSelected:
      params.get('minArea') === option.min.toString() &&
      ((option.max && params.get('maxArea') === option.max.toString()) || (!option.max && !params.get('maxArea'))),
    value: option.max ? `${option.min}-${option.max}` : `${option.min}-`,
  }))
  .filter((item: { isSelected: boolean; count: number }) => item.isSelected || item.count > 0)

const capacityRangeItems = normalizedCapacityFilterOptions
  .map((option: { min: number; max?: number }) => ({
    name:
      lang === 'pl'
        ? option.max
          ? `${option.min}–${option.max} osób`
          : `od ${option.min} osób`
        : option.max
          ? `${option.min}–${option.max} people`
          : `from ${option.min} people`,
    count: (capacityFilterSource || []).filter((item: { maxPeople: number }) => {
      if (!item?.maxPeople) return false
      return option.max ? item.maxPeople >= option.min && item.maxPeople <= option.max : item.maxPeople >= option.min
    }).length,
    isSelected:
      params.get('minCapacity') === option.min.toString() &&
      ((option.max && params.get('maxCapacity') === option.max.toString()) || (!option.max && !params.get('maxCapacity'))),
    value: option.max ? `${option.min}-${option.max}` : `${option.min}-`,
  }))
  .filter((item: { isSelected: boolean; count: number }) => item.isSelected || item.count > 0)

const locationItems = locations
  .filter((location): location is LocationOption => Boolean(location?._id && location?.slug))
  .map((location) => ({
    name: location.name,
    count: location.count,
    isSelected: location.slug === params.get('location'),
    value: location.slug,
  }))

const getSpacesCount = () => {
  if (lang === 'en') return totalItems === 1 ? t.foundSingle : t.foundMany
  if (totalItems % 10 >= 2 && totalItems % 10 <= 4 && (totalItems % 100 < 12 || totalItems % 100 > 14)) return t.foundFew
  if (totalItems === 1) return t.foundSingle
  return t.foundMany
}

const currentFilters = {
  location: params.get('location'),
  area: params.get('minArea') || params.get('maxArea'),
  minCapacity: params.has('minCapacity') ? parseInt(params.get('minCapacity') || '') : undefined,
  maxCapacity: params.has('maxCapacity') ? parseInt(params.get('maxCapacity') || '') : undefined,
}

const hasActiveFilters = Object.values(currentFilters).some(
  (value) => value !== undefined && value !== null && (Array.isArray(value) ? value.length > 0 : true)
)
const shouldDisableFilters = totalItems === 0
---

<section
  class='Listing'
  data-mobile-open='false'
  data-filter-path={t.filterPath}
  data-page-path={t.pagePath}>
  <header class='header'>
    <PortableText value={heading} heading='h1' class='heading' />
    <PortableText value={paragraph} class='paragraph' />
    {
      safeChecklist.length > 0 && (
        <ul class='checklist'>
          {safeChecklist.map((item) => (
            <li class='checklist-item'>
              <svg xmlns='http://www.w3.org/2000/svg' width='20' height='21' fill='none'>
                <path
                  fill='#F67258'
                  fill-rule='evenodd'
                  d='M7.993 3.167c-.203.173-.304.26-.413.332a2.26 2.26 0 0 1-.82.34c-.129.025-.261.036-.527.057-.668.053-1.002.08-1.28.178a2.26 2.26 0 0 0-1.38 1.38c-.098.278-.124.612-.178 1.28a4.772 4.772 0 0 1-.057.526 2.26 2.26 0 0 1-.34.82c-.072.11-.159.21-.332.414-.434.51-.652.765-.779 1.031a2.26 2.26 0 0 0 0 1.95c.127.267.345.521.78 1.031.172.203.259.305.331.413.167.249.282.527.34.82.026.129.036.262.057.528.054.667.08 1.001.179 1.28a2.26 2.26 0 0 0 1.378 1.379c.279.098.613.125 1.28.178.267.021.4.032.527.057.294.058.573.174.821.34.109.073.21.16.413.332.51.435.765.652 1.031.78a2.26 2.26 0 0 0 1.95 0c.267-.128.522-.345 1.032-.78.203-.173.304-.26.412-.332a2.26 2.26 0 0 1 .821-.34c.128-.025.261-.036.527-.057.668-.053 1.002-.08 1.28-.178a2.26 2.26 0 0 0 1.379-1.38c.098-.278.125-.612.178-1.28.021-.265.032-.398.057-.526a2.26 2.26 0 0 1 .34-.82c.073-.11.16-.21.332-.414.435-.51.652-.764.78-1.031a2.26 2.26 0 0 0 0-1.95c-.128-.266-.345-.521-.78-1.031-.172-.203-.259-.305-.332-.413a2.26 2.26 0 0 1-.34-.82 4.761 4.762 0 0 1-.057-.528c-.053-.667-.08-1.001-.178-1.28a2.26 2.26 0 0 0-1.379-1.379c-.278-.098-.612-.125-1.28-.178-.266-.021-.399-.032-.527-.057a2.26 2.26 0 0 1-.82-.34 4.762 4.762 0 0 1-.413-.332c-.51-.435-.765-.652-1.032-.78a2.26 2.26 0 0 0-1.95 0c-.266.128-.521.345-1.031.78Zm5.65 5.552a.678.678 0 1 0-.958-.959l-4.042 4.042-1.33-1.329a.678.678 0 0 0-.958.96l1.808 1.808a.678.678 0 0 0 .96 0l4.52-4.522Z'
                  clip-rule='evenodd'
                />
              </svg>
              <span class='checklist-item-text'>{item}</span>
            </li>
          ))}
        </ul>
      )
    }
    {escapeHintText && escapeHintCta && (
      <p class='escape-hint'>
        {escapeHintText}{' '}
        <a class='link' data-shade='light' href={lang === 'pl' ? '#kontakt' : '#contact'}>
          {escapeHintCta}
        </a>
      </p>
    )}
  </header>
  <div class='wrapper max-width'>
    <div class='filters'>
      <div class='sidebar-header'>
        <span>{t.filtersHeading}</span>
        <button class='close-sidebar' aria-label='Close filters'>
          <svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none'>
            <circle cx='12' cy='12' r='10' stroke='#F67258' stroke-width='1.5'></circle>
            <path d='M14.5 9.50002L9.5 14.5M9.49998 9.5L14.5 14.5' stroke='#F67258' stroke-width='1.5' stroke-linecap='round'></path>
          </svg>
        </button>
      </div>
      <div class='filters-content'>
        <SelectFilter heading={t.filters.location} items={locationItems} paramName='location' forceDisabled={shouldDisableFilters} />
        <SelectFilter heading={t.filters.area} items={areaRangeItems} paramName='area' forceDisabled={shouldDisableFilters} />
        <SelectFilter heading={t.filters.capacity} items={capacityRangeItems} paramName='capacity' forceDisabled={shouldDisableFilters} />
      </div>

      <div class='filters-actions'>
        <Button className='apply-filters' type='button' theme='primary' shade='dark' disabled>{t.apply}</Button>
        {hasActiveFilters && (
          <Button className='clear-filters' type='button' theme='secondary'>
            {t.clear}
          </Button>
        )}
      </div>
    </div>
    <div class='box'>
      <SearchBar value={params.get('search') || ''} placeholder={t.placeholder} />
      <button class='mobile-filter-button'>
        <span>{t.filterButton}</span>
        <svg xmlns='http://www.w3.org/2000/svg' width='16' height='17' fill='none'>
          <path
            fill='#F67258'
            d='M6.168 9.583a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM9.501 2.916a2 2 0 1 0 0 4 2 2 0 0 0 0-4ZM5.835 4.388a.5.5 0 0 1 0 1H1.168a.5.5 0 0 1 0-1h4.667ZM9.835 11.055a.5.5 0 0 0 0 1H14.5a.5.5 0 1 0 0-1H9.835ZM.668 11.555a.5.5 0 0 1 .5-.5h1.333a.5.5 0 0 1 0 1H1.168a.5.5 0 0 1-.5-.5ZM14.501 4.388a.5.5 0 0 1 0 1h-1.333a.5.5 0 1 1 0-1h1.333Z'
          ></path>
        </svg>
      </button>
      <Dropdown isSortingDropdown />
      <p class='count'>
        {t.foundPrefix}
        <strong>
          {totalItems}
          {getSpacesCount()}
        </strong>
      </p>
      {totalItems > 0 ? (
        <>
          <div class='listing'>
            {listing.map((item, index) => (
              <EventSpaceCard
                {...item}
                imgConfig={{
                  sizes:
                    '(max-width: 30.5625rem) 100vw, (max-width: 37.4375rem) 46vw, (max-width: 56.1875rem) 42vw, (max-width: 69.3125rem) 376px, 325px',
                  loading: index <= 3 ? 'eager' : 'lazy',
                  fetchpriority: index === 0 ? 'high' : 'auto',
                }}
              />
            ))}
          </div>
          <Pagination
            slugBase={t.pathPrefix}
            totalItems={totalItems}
            itemsPerPage={ITEMS_PER_PAGE}
            currentPage={currentPage}
            searchParams={params}
          />
        </>
      ) : (
        <div class='no-results'>
          <p><Fragment set:html={t.noResults.heading} /></p>
          <ul class='list'>
            {t.noResults.list.map((item) => <li>{item}</li>)}
          </ul>
          <Button theme='secondary' href={t.pathPrefix}>{t.noResults.button}</Button>
        </div>
      )}
    </div>
  </div>
  <div class='overlay' aria-hidden='true'></div>

  <style lang='scss'>
    .Listing {
      background-color: var(--neutral-200, #f5f1ec);

      .header {
        max-width: 85.375rem;
        margin: 0 auto;
        background: var(--neutral-100, #faf7f7);
        border-radius: 0rem 0rem 2.5rem 2.5rem;
        padding: clamp(4rem, calc(5.25vw / 0.48), 5.25rem) var(--pageMargin) 2rem;
        display: grid;
        grid-template-columns: minmax(auto, 40.9375rem);
        justify-content: center;
        text-align: center;

        .heading {
          margin-bottom: 0.75rem;
        }
        .paragraph {
          margin-bottom: clamp(0.75rem, calc(1.75vw / 0.48), 1.75rem);
          font-size: var(--typography-body-xl, 1.125rem);
          line-height: 1.5;
        }
        .checklist {
          display: flex;
          gap: 0.375rem 1.5rem;
          flex-wrap: wrap;
          justify-content: center;
          align-items: center;

          li {
            display: flex;
            align-items: start;
            gap: 0.5rem;
            font-size: var(--typography-body-xl, 1.125rem);
            line-height: 1.5;

            svg {
              margin-top: 3px;
            }
          }
        }

        .escape-hint {
          margin-top: clamp(0.75rem, calc(1vw / 0.48), 1rem);
          padding-left: 0.75rem;
          position: relative;
          font-size: var(--typography-body-m, 0.875rem);
          color: var(--primary-400, #94a3b8);
          line-height: 1.5;
          justify-self: center;
          max-width: max-content;
          z-index: 10;

          &::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0.125rem;
            bottom: 0.125rem;
            width: 1px;
            background-color: var(--primary-500, #db664e);
            opacity: 0.7;
          }
        }
      }

      .wrapper {
        padding: 3rem 0;
        display: grid;
        grid-template-columns: 20.4375rem 1fr;
        gap: 2rem;

        .mobile-filter-button {
          display: none;
          align-items: center;
          gap: 0.5rem;
          min-height: 2.75rem;
          padding: 0 0.625rem;
          border-radius: 0.5rem;
          color: var(--primary-800, #45051c);
          line-height: 1.7;
          font-size: var(--typography-body-m, 0.875rem);
          background-color: var(--neutral-100);
          letter-spacing: -0.01em;
          min-width: 5rem;
          justify-content: center;
          border: 1px solid var(--neutral-500, #d2c1b0);
          cursor: pointer;
          transition: border-color 150ms;
          grid-column: 2/3;
          grid-row: 2/3;
          svg {
            margin-top: 3px;
            transition: transform 250ms cubic-bezier(0.18, 0.89, 0.32, 1.27);
          }

          &:hover {
            border-color: var(--primary-700, #600d2a);

            svg {
              transform: scale(1.1);
            }
          }
        }

        .filters {
          width: 100%;
          display: flex;
          flex-direction: column;
          position: relative;

          .sidebar-header {
            display: none;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.625rem;

            span {
              font-family: 'PF Grand Gothik', 'PF Grand Gothik Fallback', sans-serif;
              color: var(--primary-700, #600d2a);
              line-height: 0.9;
              letter-spacing: -0.065em;
              font-size: var(--typography-heading-l, 2rem);
              text-transform: uppercase;
              font-weight: 760;
              margin-top: 8px;
            }

            .close-sidebar {
              position: relative;
              isolation: isolate;
              border-radius: 50%;
              min-width: 2.75rem;
              min-height: 2.75rem;
              display: grid;
              place-items: center;
              transition: transform 300ms var(--easing);

              &::before {
                content: '';
                position: absolute;
                inset: 0;
                background: var(--neutral-100, #f5f1ec);
                border-radius: 50%;
                transform: scale(0);
                transition: transform 300ms var(--easing);
                z-index: -1;
              }

              &:hover {
                transform: scale(1.2);
                &::before {
                  transform: scale(1);
                }
              }

              &:focus:not(:focus-visible) {
                transform: scale(1);
              }

              &:focus-visible {
                outline-offset: -2px;
              }
            }
          }

          .filters-content {
            display: flex;
            flex-direction: column;
            background-color: var(--neutral-100);
            border-radius: 0.5rem 0.5rem 0 0;
            // padding-bottom: 5rem;
            :global(.stars-row) {
              display: flex;
              align-items: center;
              gap: 0.125rem;

              svg {
                width: 0.875rem;
                height: 0.875rem;
              }
            }
          }

          .filters-actions {
            position: sticky;
            bottom: 0;
            background-color: var(--neutral-100);
            border-radius: 0 0 0.5rem 0.5rem;
            padding: 1rem;
            border-top: 1px solid var(--neutral-300, #e8ddd1);
            display: none;
            flex-direction: column;
            gap: 0.5rem;
            z-index: 10;
          }

          :global(button) {
            max-width: 100%;
            width: 100%;

            &[data-theme='secondary'] {
              display: flex;
              justify-content: center;
              margin-top: 0;
            }

            &[data-theme='primary'] {
              margin-top: 0;
              display: none;
              :global(span) {
                margin: 0 auto;
                padding-right: 1.75rem;
              }
            }
          }
        }

        :global(> button) {
          display: none;
        }

        .box {
          justify-self: end;
          max-width: 54.75rem;
          display: grid;
          width: 100%;
          grid-template-columns: repeat(2, 1fr);
          justify-content: space-between;
          grid-template-rows: auto auto auto 1fr;
          column-gap: clamp(0.25rem, calc(0.5vw / 0.48), 0.75rem);

          :global(.SearchBar) {
            grid-column: 1/2;
            grid-row: 1/2;
            width: 100%;
            max-width: 20.3125rem;
            align-self: center;
            margin: 0;
          }

          :global(.filter-dropdown) {
            grid-column: 2/3;
            grid-row: 1/2;
            width: 100%;
            max-width: 20.3125rem;
            justify-self: end;
            align-self: center;
          }

          .count {
            grid-column: 1/2;
            grid-row: 2/3;
            margin: 0.875rem 0 0.375rem;
            font-size: var(--typography-body-m, 0.875rem);
            letter-spacing: -0.01em;
            line-height: 1.7;

            :global(strong) {
              font-size: var(--typography-body-m, 0.875rem);
              font-weight: 700;
              letter-spacing: -0.02em;
              color: var(--primary-800, #45051c);
            }
          }

          .listing {
            grid-column: 1/3;
            grid-row: 3/4;
            gap: clamp(0.625rem, calc(0.75vw / 0.48), 0.75rem);
            display: grid;
            grid-template-columns: 1fr;
            align-self: start;
          }
          :global(.Pagination) {
            grid-column: 1/3;
            grid-row: 4/5;
            margin-top: 3rem;
            align-self: start;
          }

          .no-results {
            grid-column: 1/3;
            grid-row: 3/5;
            display: flex;
            flex-direction: column;
            justify-self: center;
            max-width: 27.125rem;
            margin: clamp(3rem, calc(4vw / 0.48), 4rem) 0;

            p {
              font-size: var(--typography-body-2xl, 1.5rem);
              letter-spacing: -0.035em;
              line-height: 1.25;
              margin-bottom: clamp(0.75rem, calc(1vw / 0.48), 1rem);

              :global(strong) {
                color: var(--primary-800, #45051c);
                font-weight: 700;
                letter-spacing: -0.04em;
              }
            }

            ul {
              margin-bottom: clamp(2rem, calc(2.5vw / 0.48), 2.5rem);
              li {
                display: grid;
                gap: 0.5rem;
                grid-template-columns: auto 1fr;
                font-size: var(--typography-body-xl, 1.125rem);

                line-height: 1.5;
                letter-spacing: -0.02em;

                &::before {
                  content: '';
                  width: 0.25rem;
                  height: 0.25rem;
                  border-radius: 50%;
                  background-color: var(--primary-400, #74535e);
                  margin-top: 0.825rem;
                }
                &:not(:last-child) {
                  margin-bottom: clamp(0.25rem, calc(0.375vw / 0.48), 0.375rem);
                }
              }
            }
          }
        }
      }

      .overlay {
        position: fixed;
        inset: 0;
        background-color: rgba(237, 230, 222, 0.25);
        backdrop-filter: blur(6px);
        top: 0;
        z-index: 100;
        left: 0;
        width: 100%;
        height: 100vh;
        opacity: 0;
        visibility: hidden;
        transition:
          opacity 200ms,
          visibility 200ms;

        &[aria-hidden='false'] {
          opacity: 1;
          visibility: visible;
        }
      }

      @media (max-width: 69.3125rem) {
        .wrapper {
          grid-template-columns: 1fr;
          display: block;

          .mobile-filter-button {
            display: flex;
          }

          .filters {
            position: fixed;
            top: 0;
            left: 0;
            z-index: 150;
            width: 100%;
            max-width: clamp(22.5rem, calc(33.3125vw / 0.48), 33.3125rem);
            height: 100vh;
            background: var(--neutral-200);
            transform: translateX(-50%);
            opacity: 0;
            visibility: hidden;
            transition:
              opacity 100ms,
              visibility 100ms,
              transform 250ms var(--easing);
            display: flex;
            flex-direction: column;
            border-right: 2px solid;
            border-image: linear-gradient(0deg, #798ddc 0%, #e7c78f 25%, #fa7468 74%, #798ddc 100%) 1;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
            padding: clamp(1.5rem, calc(4vw / 0.48), 4rem) clamp(1rem, calc(4vw / 0.48), 4rem);

            .filters-content {
              overflow-y: auto;
              padding-right: 0.75rem;
              display: flex;
              flex-direction: column;
              height: max-content;
              border-radius: 0.5rem 0.5rem 0 0;
              flex: 1;
              padding-bottom: 0;

              :global(> details) {
                flex-shrink: 0 !important;
              }
            }

            .filters-actions {
              position: sticky;
              bottom: 0;
              z-index: 10;
            }

            .sidebar-header {
              display: flex;
            }

            &[aria-hidden='false'] {
              transform: translateX(0);
              opacity: 1;
              visibility: visible;
            }
          }

          .box {
            grid-column: 1/2;
            grid-row: 1/2;
            grid-template-columns: 1fr auto auto;
            grid-template-rows: auto auto 1fr;
            max-width: 48rem;
            margin: 0 auto;

            :global(.SearchBar) {
              grid-column: 1/4;
              grid-row: 1/2;
              max-width: 100%;
              margin-bottom: 0.375rem;
            }

            :global(.filter-dropdown) {
              grid-column: 3/4;
              grid-row: 2/3;
              width: clamp(15.25rem, calc(18.625vw / 0.48), 18.625rem);
            }

            .count {
              grid-column: 1/2;
              grid-row: 2/3;
            }

            .listing {
              margin-top: 1rem;
              grid-column: 1/4;
              grid-row: 3/4;
              display: grid;
              grid-template-columns: repeat(2, 1fr);
            }

            :global(.Pagination) {
              grid-column: 1/4;
              grid-row: 4/5;
            }

            .no-results {
              grid-column: 1/4;
              grid-row: 3/5;
              justify-self: start;
            }
          }
        }
      }

      @media (max-width: 30.5625rem) {
        .header {
          display: block;
          text-align: start;

          .paragraph {
            margin-bottom: 0.75rem;
          }

          .checklist {
            flex-direction: column;
            background: var(--neutral-200, #f5f1ec);
            border-radius: 0.5rem;
            align-items: flex-start;
            padding: 0.625rem 0.625rem 0.75rem 0.625rem;
          }
        }

        .wrapper {
          .filters {
            max-width: 86vw;
          }
          .box {
            .listing {
              grid-template-columns: 1fr;
            }

            .no-results {
              :global(a) {
                max-width: 100%;
                width: 100%;

                display: flex;
                justify-content: center;
              }
            }
          }
        }
      }

      @media (max-width: 27.4375rem) {
        .wrapper .filters {
          max-width: 86vw;
          padding: 1.5rem 1rem;
        }
      }

      @media (max-width: 31.1875rem) {
        .wrapper {
          .box {
            grid-template-columns: auto 1fr;

            .listing {
              grid-column: 1/3;
              grid-row: 4/5;
            }

            .mobile-filter-button {
              grid-column: 1/2;
              grid-row: 2/3;
            }

            .count {
              grid-column: 1/3;
              grid-row: 3/4;
              justify-self: start;
            }

            :global(.filter-dropdown) {
              grid-column: 2/3;
              grid-row: 2/3;
              width: 100%;
            }

            :global(.SearchBar) {
              grid-column: 1/3;
              grid-row: 1/2;
            }

            .no-results {
              grid-column: 1/3;
            }

            :global(.Pagination) {
              grid-column: 1/3;
              grid-row: 5/6;
            }
          }
        }
      }

      @media (max-width: 23.0625rem) {
        .wrapper {
          .box {
            .listing {
              grid-column: 1/2;
              grid-row: 5/6;
            }

            .no-results {
              grid-column: 1/2;
              grid-row: 5/6;
            }

            :global(.Pagination) {
              grid-column: 1/2;
              grid-row: 6/7;
            }
            .count {
              grid-column: 1/2;
              grid-row: 4/5;
            }

            .mobile-filter-button {
              grid-column: 1/2;
              grid-row: 2/3;
              margin-bottom: 0.5rem;
            }

            :global(.filter-dropdown) {
              grid-column: 1/2;
              grid-row: 3/4;
              max-width: 100%;
            }

            :global(.SearchBar) {
              grid-column: 1/2;
              grid-row: 1/2;
            }
          }
        }
      }
    }
  </style>

  <script>
    type FilterValue = string | number | null
    const params = new URLSearchParams(window.location.search)
    const initialFilters: Record<string, FilterValue> = {
      location: params.get('location'),
      area: null,
    capacity: null,
    }

    const applyButton = document.querySelector<HTMLButtonElement>('.apply-filters')
    const clearButton = document.querySelector<HTMLButtonElement>('.clear-filters')
    const listingSection = document.querySelector<HTMLElement>('.Listing')! as HTMLElement

    const initialUrlState = {
      location: params.get('location'),
      area: (() => {
        const min = params.get('minArea')
        const max = params.get('maxArea')
        if (min && max) return `${min}-${max}`
        if (min && !max) return `${min}-`
        return null
      })(),
    capacity: (() => {
      const min = params.get('minCapacity')
      const max = params.get('maxCapacity')
      if (min && max) return `${min}-${max}`
      if (min && !max) return `${min}-`
      return null
    })(),
    }

    function updateFiltersActionsVisibility() {
      const container = document.querySelector<HTMLElement>('.filters-actions')
      if (!container) return
      const applyVisible = applyButton && window.getComputedStyle(applyButton).display !== 'none'
      const clearVisible = !!clearButton
      container.style.display = applyVisible || clearVisible ? 'flex' : 'none'
    }

    function checkFiltersChanged() {
      let changed = false
      document.querySelectorAll<HTMLDetailsElement>('.filter-group').forEach((filterGroup) => {
        const paramName = filterGroup.dataset.paramName
        if (!paramName) return

      changed ||= initialFilters[paramName] !== initialUrlState[paramName as keyof typeof initialUrlState]
      })

      if (applyButton) {
        applyButton.style.display = changed ? 'flex' : 'none'
        applyButton.disabled = !changed
      }
      updateFiltersActionsVisibility()
    }

    window.addEventListener('filterChange', ((e: CustomEvent) => {
      const { paramName, value, minValue, maxValue } = e.detail || {}
      initialFilters[paramName] = value || (typeof minValue === 'number' && typeof maxValue === 'number' ? `${minValue}-${maxValue}` : null)
      checkFiltersChanged()
    }) as EventListener)

    window.addEventListener('filterClear', ((e: CustomEvent) => {
      const { paramName } = e.detail || {}
      initialFilters[paramName] = null
      checkFiltersChanged()
    }) as EventListener)

    function applyFilters() {
      const currentPath = window.location.pathname
      const params = new URLSearchParams(window.location.search)
      ;['location', 'minArea', 'maxArea', 'minCapacity', 'maxCapacity'].forEach((param) => params.delete(param))

      document.querySelectorAll<HTMLDetailsElement>('.filter-group').forEach((filterGroup) => {
        const paramName = filterGroup.dataset.paramName
        if (!paramName) return

        if (paramName === 'area') {
          const selectedInput = filterGroup.querySelector<HTMLInputElement>('input[type="radio"]:checked')
          const wasSelected = selectedInput?.parentElement?.getAttribute('data-selected') === 'true'
          if (selectedInput && wasSelected) {
            const [min, max] = selectedInput.value.split('-')
            if (min) params.set('minArea', min)
            if (max) params.set('maxArea', max)
          }
        } else if (paramName === 'capacity') {
          const selectedInput = filterGroup.querySelector<HTMLInputElement>('input[type="radio"]:checked')
          const wasSelected = selectedInput?.parentElement?.getAttribute('data-selected') === 'true'
          if (selectedInput && wasSelected) {
            const [min, max] = selectedInput.value.split('-')
            if (min) params.set('minCapacity', min)
            if (max) params.set('maxCapacity', max)
          }
        } else {
          const selectedInput = filterGroup.querySelector<HTMLInputElement>('input[type="radio"]:checked')
          const wasSelected = selectedInput?.parentElement?.getAttribute('data-selected') === 'true'
          if (selectedInput && wasSelected) params.set(paramName, selectedInput.value)
        }
      })

      const filterPathSegment = listingSection.getAttribute('data-filter-path') || 'filtr'
      const pagePathSegment = listingSection.getAttribute('data-page-path') || 'strona'
      let basePath = currentPath
      if (basePath.includes(`/${filterPathSegment}`)) basePath = basePath.replace(`/${filterPathSegment}/`, '/').replace(`/${filterPathSegment}`, '/')
      if (basePath.includes(`/${pagePathSegment}/`)) basePath = basePath.replace(new RegExp(`\\/${pagePathSegment}\\/\\d+\\/?`), '/')
      if (!basePath.endsWith('/')) basePath += '/'
      const finalUrl = `${basePath}${filterPathSegment}/${params.toString() ? `?${params.toString()}` : ''}`
      window.location.href = finalUrl
    }

    applyButton?.addEventListener('click', applyFilters)
    clearButton?.addEventListener('click', () => {
      const filterPathSegment = listingSection.getAttribute('data-filter-path') || 'filtr'
      let clearPath = window.location.pathname
      if (clearPath.includes(`/${filterPathSegment}`)) clearPath = clearPath.replace(`/${filterPathSegment}/`, '/').replace(`/${filterPathSegment}`, '/')
      window.location.href = clearPath
    })

    window.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll<HTMLDetailsElement>('.filter-group').forEach((filterGroup) => {
        const paramName = filterGroup.dataset.paramName
        if (!paramName) return
        const value = initialUrlState[paramName as keyof typeof initialUrlState]
        initialFilters[paramName] = value as FilterValue
        if (value) {
          filterGroup.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((input) => {
            const isMatch = input.value === value
            input.checked = isMatch
            input.parentElement?.setAttribute('data-selected', String(isMatch))
          })
        }
      })
      updateFiltersActionsVisibility()
    })

    const filterButton = listingSection.querySelector<HTMLButtonElement>('.mobile-filter-button')! as HTMLButtonElement
    const sidebar = listingSection.querySelector<HTMLDivElement>('.filters')! as HTMLDivElement
    const closeButton = listingSection.querySelector<HTMLButtonElement>('.close-sidebar')! as HTMLButtonElement
    const overlay = listingSection.querySelector<HTMLDivElement>('.overlay')! as HTMLDivElement

    filterButton.addEventListener('click', () => {
      listingSection.setAttribute('data-mobile-open', 'true')
      sidebar.setAttribute('aria-hidden', 'false')
      overlay.setAttribute('aria-hidden', 'false')
    })

    closeButton.addEventListener('click', () => {
      listingSection.setAttribute('data-mobile-open', 'false')
      sidebar.setAttribute('aria-hidden', 'true')
      overlay.setAttribute('aria-hidden', 'true')
    })

    overlay.addEventListener('click', () => {
      listingSection.setAttribute('data-mobile-open', 'false')
      sidebar.setAttribute('aria-hidden', 'true')
      overlay.setAttribute('aria-hidden', 'true')
    })

    let currentWidth = window.innerWidth
    window.addEventListener('resize', () => {
      if (currentWidth !== window.innerWidth) {
        currentWidth = window.innerWidth
        const isMobile = currentWidth < 1109

        if (!isMobile && listingSection) {
          if (sidebar && overlay && sidebar.getAttribute('aria-hidden') === 'false') {
            listingSection.setAttribute('data-mobile-open', 'false')
            sidebar.setAttribute('aria-hidden', 'true')
            overlay.setAttribute('aria-hidden', 'true')
          }
        }
      }
    })
  </script>
