---
import { getLangFromPath, type Language } from '@/src/global/languages'
import Image, { ImageDataQuery, type ImageDataProps } from './image'
import Button from './Button'

export const EventSpaceCardQuery = `
  _id,
  name,
  "slug": slug.current,
  "previewImage": coalesce(
    ${ImageDataQuery('mediaList[0].image')}
    ${ImageDataQuery('imageList[0]')}
  ),
  address,
  areaM2,
  maxPeople,
  pricing
`

export type EventSpaceCardProps = {
  _id: string
  name: string
  slug: string
  previewImage?: ImageDataProps
  address: {
    city: string
    street: string
    postalCode: string
    voivodeship: string
  }
  areaM2: number
  maxPeople: number
  pricing?: {
    pricingVisible?: boolean
    displayMode?: 'quoteOnly' | 'fromPrice'
    fromPrice?: number
    priceLabel?: string
  }
  imgConfig: {
    sizes: string
    loading: 'lazy' | 'eager'
    fetchpriority: 'auto' | 'high'
  }
}

const translations = {
  pl: {
    pricing: {
      from: 'od',
      notAvailable: 'Cena dostępna w wycenie',
    },
    capacity: 'Maks.',
    people: 'osób',
    area: 'm2',
    button: 'Sprawdź przestrzeń',
    buttonFull: 'Przejdź do widoku przestrzeni eventowej',
  },
  en: {
    pricing: {
      from: 'from',
      notAvailable: 'Price available on request',
    },
    capacity: 'Max.',
    people: 'people',
    area: 'm2',
    button: 'Check venue',
    buttonFull: 'Go to event space view',
  },
} as const

const t = translations[(getLangFromPath(Astro.url.pathname) as Language) || 'pl']

const { name, slug, previewImage, address, areaM2, maxPeople, pricing, imgConfig, _id } =
  Astro.props as EventSpaceCardProps

const getVoivodeship = (voivodeship: string) => {
  switch (voivodeship) {
    case 'dolnoslaskie':
      return 'Dolnośląskie'
    case 'kujawsko-pomorskie':
      return 'Kujawsko-pomorskie'
    case 'lubelskie':
      return 'Lubelskie'
    case 'lubuskie':
      return 'Lubuskie'
    case 'lodzkie':
      return 'Łódzkie'
    case 'malopolskie':
      return 'Małopolskie'
    case 'mazowieckie':
      return 'Mazowieckie'
    case 'opolskie':
      return 'Opolskie'
    case 'podkarpackie':
      return 'Podkarpackie'
    case 'podlaskie':
      return 'Podlaskie'
    case 'pomorskie':
      return 'Pomorskie'
    case 'slaskie':
      return 'Śląskie'
    case 'swietokrzyskie':
      return 'Świętokrzyskie'
    case 'warminsko-mazurskie':
      return 'Warmińsko-mazurskie'
    case 'wielkopolskie':
      return 'Wielkopolskie'
    case 'zachodniopomorskie':
      return 'Zachodniopomorskie'
    default:
      return voivodeship
  }
}

const pricingText =
  pricing?.pricingVisible && pricing?.displayMode === 'fromPrice' && pricing?.fromPrice
    ? `${t.pricing.from} ${pricing.fromPrice} ${pricing.priceLabel || 'PLN'}`
    : t.pricing.notAvailable
---

<article class="EventSpaceCard" data-id={_id}>
  <div class="wrapper">
    <a href={slug} class="background" aria-label={t.buttonFull}></a>
    <div class="img-box">
      {previewImage && <Image {...previewImage} {...imgConfig} />}
    </div>
    <div class="content">
      <span class="title">{name}</span>
      <div class="details">
        <span class="address">{address.city}, {getVoivodeship(address.voivodeship)}</span>
        <span class="meta">{areaM2} {t.area}</span>
        <span class="meta">{t.capacity} {maxPeople} {t.people}</span>
        <span class="price">{pricingText}</span>
      </div>
      <Button href={slug} tabIndex={-1} theme="primary">{t.button}</Button>
    </div>
  </div>
</article>

<style lang="scss">
  .EventSpaceCard {
    border-radius: 0.75rem;
    overflow: hidden;
    padding: 1px;
    position: relative;
    background: conic-gradient(
      from 135deg at 50% 50%,
      #798ddc 0deg,
      #e7c78f 90deg,
      #fa7468 266.4deg,
      #798ddc 360deg
    );

    .wrapper {
      position: relative;
      display: grid;
      grid-template-columns: minmax(16rem, 20rem) 1fr;
      gap: 1rem 1.5rem;
      height: 100%;
      background: var(--neutral-100);
      border-radius: 0.7rem;
      padding: 0.375rem 1rem 0.375rem 0.375rem;
      align-items: center;
    }

    .background {
      position: absolute;
      inset: 0;
      z-index: 0;
    }

    .img-box {
      position: relative;
      z-index: 1;
      min-height: 100%;
      overflow: hidden;
      border-radius: 0.5rem;

      img {
        width: 100%;
        height: 100%;
        min-height: 14rem;
        object-fit: cover;
      }
    }

    .content {
      position: relative;
      z-index: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      padding: 1rem 0;
    }

    .title {
      color: var(--primary-800, #45051c);
      font-size: var(--typography-body-2xl, 1.5rem);
      font-weight: 700;
      line-height: 1.25;
      letter-spacing: -0.04em;
      margin-bottom: 1rem;
    }

    .details {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      margin-bottom: 1rem;
    }

    .address,
    .meta,
    .price {
      color: var(--primary-700, #600d2a);
      font-size: var(--typography-body-m, 0.875rem);
      line-height: 1.6;
    }

    .address {
      width: 100%;
      color: var(--primary-800, #45051c);
      font-weight: 600;
    }

    @media (max-width: 56.1875rem) {
      .wrapper {
        grid-template-columns: 1fr;
        padding: 0.375rem;
      }

      .content {
        padding: 0.75rem;
      }
    }
  }
</style>
