---
import { sanityImageUrl, sanityImageSrcset } from '@/utils/sanity-image'

export type ImageDataProps = {
  asset: {
    url: string
    altText: string
    extension: string
    metadata: {
      dimensions: {
        width: number
        height: number
      }
      lqip: string
    }
  }
}

type Props = ImageDataProps & {
  sizes: string
  priority?: boolean
} & Omit<astroHTML.JSX.ImgHTMLAttributes, 'src' | 'alt' | 'width' | 'height'>

const { asset, sizes, priority, ...props } = Astro.props

const MAX_WIDTH = 2560
const WIDTHS = [48, 64, 96, 128, 256, 384, 640, 750, 828, 1080, 1200, 1920, 2048, 2560]

const originalWidth = asset.metadata.dimensions.width
const originalHeight = asset.metadata.dimensions.height

const width = Math.min(originalWidth, MAX_WIDTH)
const height =
  originalWidth > MAX_WIDTH ? Math.round((originalHeight * MAX_WIDTH) / originalWidth) : originalHeight

const isSvg = asset.extension === 'svg'
---

{
  isSvg ? (
    <img
      src={asset.url}
      alt={asset.altText || ''}
      width={width}
      height={height}
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      {...(priority && { fetchpriority: 'high' })}
      {...props}
    />
  ) : (
    <img
      src={sanityImageUrl(asset.url, { w: width })}
      srcset={sanityImageSrcset(asset.url, WIDTHS, originalWidth)}
      sizes={sizes}
      alt={asset.altText || ''}
      width={width}
      height={height}
      style={`background:url(${asset.metadata.lqip}) center / cover no-repeat`}
      onload="this.removeAttribute('style')"
      loading={priority ? 'eager' : 'lazy'}
      decoding="async"
      {...(priority && { fetchpriority: 'high' })}
      {...props}
    />
  )
}
