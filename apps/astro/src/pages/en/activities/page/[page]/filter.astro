---
export const prerender = false

import ActivitiesListing, { fetchData } from '@/src/templates/activities/CategoriesPage.astro'

const data = await fetchData('en', Astro.url.origin, Astro.url.searchParams)

const canonicalUrl = Astro.url.origin + '/en/activities/'

if (!data) return Astro.rewrite('/en/404')
---

<ActivitiesListing {...data} canonicalUrl={canonicalUrl} doNotIndex={true} />
