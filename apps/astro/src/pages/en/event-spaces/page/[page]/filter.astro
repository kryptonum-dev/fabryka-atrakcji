---
export const prerender = false

import EventSpacesListing, { fetchData, staticPaths } from '@/src/templates/event-spaces/EventSpacesPage.astro'

const page = parseInt(Astro.params.page || '1')
const data = await fetchData('en', page, Astro.url.origin, Astro.url.searchParams)
const canonicalUrl = Astro.url.origin + `/en/event-spaces/page/${page}/`

if (!data) return Astro.rewrite('/en/404')

export const getStaticPaths = () => staticPaths('en')
---

<EventSpacesListing {...data} currentPage={page} canonicalUrl={canonicalUrl} doNotIndex={true} />
