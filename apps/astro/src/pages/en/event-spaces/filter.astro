---
export const prerender = false

import EventSpacesListing, { fetchData } from '@/src/templates/event-spaces/EventSpacesPage.astro'

const data = await fetchData('en', 1, Astro.url.origin, Astro.url.searchParams)
const canonicalUrl = Astro.url.origin + '/en/event-spaces/'

if (!data) return Astro.rewrite('/en/404')
---

<EventSpacesListing {...data} currentPage={1} canonicalUrl={canonicalUrl} doNotIndex={true} />
