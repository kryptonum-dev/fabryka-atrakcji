---
import SingleEventSpacePage, { fetchData, staticPaths } from '@/src/templates/event-spaces/SingleEventSpacePage.astro'

const data = await fetchData(Astro.params.slug || '', 'en')

if (!data) return Astro.rewrite('/en/404')

export const getStaticPaths = () => staticPaths('en')
---

<SingleEventSpacePage {...data} />
