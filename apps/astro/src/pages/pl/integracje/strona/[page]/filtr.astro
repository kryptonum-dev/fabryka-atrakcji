---
export const prerender = false

import ActivitiesListing, { fetchData } from '@/src/templates/activities/CategoriesPage.astro'

const data = await fetchData('pl', Astro.url.origin, Astro.url.searchParams)

const canonicalUrl = Astro.url.origin + '/pl/integracje/'

if (!data) return Astro.rewrite('/pl/404')
---

<ActivitiesListing {...data} canonicalUrl={canonicalUrl} doNotIndex={true} />
