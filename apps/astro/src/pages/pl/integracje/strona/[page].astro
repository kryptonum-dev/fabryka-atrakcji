---
import ActivitiesListing, { fetchData } from '@/src/templates/activities/CategoriesPage.astro'

const data = await fetchData('pl', Astro.url.origin)

if (!data) return Astro.rewrite('/pl/404')

export async function getStaticPaths() {
  return [{ params: { page: '2' } }]
}
---

<ActivitiesListing {...data} />
