---
import Layout from '@/src/layouts/Layout.astro'
import type { Language } from '@/global/languages'
import { getLangFromPath } from '@/src/global/languages'
import Breadcrumbs from '@/src/layouts/Breadcrumbs.astro'
import sanityFetch from '@/src/utils/sanity.fetch'
import metadataFetch from '@/src/utils/metadata.fetch'
import Image, { ImageDataQuery, type ImageDataProps } from '@/src/components/ui/image'
import { PortableTextQuery, type PortableTextValue } from '@/src/components/ui/portable-text'
import PortableText from '@/src/components/ui/portable-text'
import Components, { Components_Query, type ComponentsProps } from '@/src/components/Components.astro'
import ContentPT, { type Props as ContentPTProps, ContentPT_Query } from '@/src/components/ui/content-pt/index.astro'
import Button from '@/src/components/ui/Button'
import Faq, { Faq_Query } from '@/src/components/ui/content-pt/offer/Faq.astro'
import Testimonials, { Testimonials_Query } from '@/src/components/ui/content-pt/offer/Testimonials.astro'
import Location, { Location_Query } from '@/src/components/ui/content-pt/hotel/Location.astro'
import Checklist, { Checklist_Query } from '@/src/components/ui/content-pt/shared/Checklist.astro'
import BlocksWithImage, { BlocksWithImage_Query } from '@/src/components/ui/content-pt/offer/BlocksWithImage.astro'
import ImageWithHeadingAndText, {
  ImageWithHeadingAndText_Query,
} from '@/src/components/ui/content-pt/offer/ImageWithHeadingAndText.astro'
import RowsWithIcons, { RowsWithIcons_Query } from '@/src/components/ui/content-pt/offer/RowsWithIcons.astro'
import Timeline, { Timeline_Query } from '@/src/components/ui/content-pt/offer/Timeline.astro'
import NextSteps, { NextSteps_Query } from '@/src/components/ui/content-pt/offer/NextSteps.astro'
import ContactForm from '@/src/components/global/ContactForm/index.astro'
import type { FormStateTypes } from '@/src/global/types'

type SingleEventSpaceProps = {
  _id: string
  _type: 'EventSpaces_Collection'
  name: string
  slug: string
  title: PortableTextValue
  description: string
  mediaList?: Array<{
    image: ImageDataProps
    youtubeId?: string
  }>
  imageList?: ImageDataProps[]
  location: {
    _id: string
    name: string
  }
  areaM2: number
  maxPeople: number
  address: {
    street: string
    postalCode: string
    city: string
    voivodeship: string
  }
  googleMaps: {
    googleMapsLink: string
  }
  popularityIndex: number
  pricing?: {
    pricingVisible?: boolean
    displayMode?: 'quoteOnly' | 'fromPrice'
    fromPrice?: number
    priceLabel?: string
  }
  globalFormDefaults?: {
    heading?: PortableTextValue
    paragraph?: PortableTextValue
  }
  eventSpacesPage: {
    name: string
    slug: string
    detailFormDefaults?: {
      heading?: PortableTextValue
      paragraph?: PortableTextValue
      formVisualImage?: ImageDataProps
      overrideFormState?: boolean
      formState?: FormStateTypes
    }
  }
  formOverrides?: {
    heading?: PortableTextValue
    paragraph?: PortableTextValue
    formVisualImage?: ImageDataProps
    overrideFormState?: boolean
    formState?: FormStateTypes
  }
  components: ComponentsProps
  content: ContentPTProps['value']
}

export async function fetchData(slug: string, lang: Language) {
  const prefixes = {
    pl: '/pl/przestrzenie-eventowe/',
    en: '/en/event-spaces/',
  }

  const page = await sanityFetch<SingleEventSpaceProps>({
    query: `
      *[_type == 'EventSpaces_Collection' && language == $language && slug.current == $slug][0] {
        _id,
        "globalFormDefaults": *[_type == "global" && language == $language][0].inquiryFormDefaults {
          ${PortableTextQuery('heading')}
          ${PortableTextQuery('paragraph')}
        },
        "eventSpacesPage": *[_type == "EventSpaces_Page" && language == $language][0] {
          name,
          "slug": slug.current,
          detailFormDefaults {
            ${PortableTextQuery('heading')}
            ${PortableTextQuery('paragraph')}
            ${ImageDataQuery('formVisualImage')}
            overrideFormState,
            formState {
              success {
                ${PortableTextQuery('heading')}
                ${PortableTextQuery('paragraph')}
                highlightedSocialMedia[] -> {
                  name,
                  link,
                  iconString,
                },
              },
              error {
                ${PortableTextQuery('heading')}
                ${PortableTextQuery('paragraph')}
              },
            },
          },
        },
        _type,
        name,
        "slug": slug.current,
        ${PortableTextQuery('title')}
        description,
        mediaList[]{
          ${ImageDataQuery('image')}
          youtubeId
        },
        ${ImageDataQuery('imageList[]')}
        location->{
          _id,
          name
        },
        areaM2,
        maxPeople,
        address,
        googleMaps{
          googleMapsLink,
        },
        popularityIndex,
        pricing,
        ${ContentPT_Query([Faq_Query, Testimonials_Query, Location_Query, Checklist_Query, BlocksWithImage_Query, ImageWithHeadingAndText_Query, RowsWithIcons_Query, Timeline_Query, NextSteps_Query])}
        formOverrides {
          ${PortableTextQuery('heading')}
          ${PortableTextQuery('paragraph')}
          ${ImageDataQuery('formVisualImage')}
          overrideFormState,
          formState {
            success {
              ${PortableTextQuery('heading')}
              ${PortableTextQuery('paragraph')}
              highlightedSocialMedia[] -> {
                name,
                link,
                iconString,
              },
            },
            error {
              ${PortableTextQuery('heading')}
              ${PortableTextQuery('paragraph')}
            },
          },
        },
        ${Components_Query}
      }
    `,
    params: { language: lang, slug: `${prefixes[lang]}${slug}/` },
  })

  if (!page) return null
  const metadata = await metadataFetch(page.slug)
  return metadata ? { page, metadata } : null
}

export async function staticPaths(lang: Language) {
  const pages = await sanityFetch<{ slug: string }[]>({
    query: `
      *[_type == 'EventSpaces_Collection' && language == $language][] {
        "slug": slug.current,
      }
    `,
    params: { language: lang },
  })

  return pages?.map(({ slug }) => ({
    params: { slug: slug.split('/').slice(-2).join('/') },
  }))
}

const { page, metadata } = Astro.props as NonNullable<Awaited<ReturnType<typeof fetchData>>>
const lang = (getLangFromPath(Astro.url.pathname) as Language) || 'pl'

const translations = {
  pl: {
    area: 'Powierzchnia',
    capacity: 'Maks. liczba osób',
    showOnMap: 'Pokaż na mapie',
    pricingFrom: 'Cena od',
    pricingQuoteOnly: 'Cena dostępna w wycenie',
    askForQuote: 'Zapytaj o wycenę',
    addToInquiry: 'Dodaj do zapytania',
    removeFromInquiry: 'Usuń z zapytania',
    addedAlert: 'Dodano do zapytania',
    removedAlert: 'Usunięto z zapytania',
  },
  en: {
    area: 'Area',
    capacity: 'Max people',
    showOnMap: 'Show on map',
    pricingFrom: 'Price from',
    pricingQuoteOnly: 'Price available on request',
    askForQuote: 'Ask for a quote',
    addToInquiry: 'Add to inquiry',
    removeFromInquiry: 'Remove from inquiry',
    addedAlert: 'Added to inquiry',
    removedAlert: 'Removed from inquiry',
  },
} as const

const t = translations[lang]

const mediaItems =
  page.mediaList && page.mediaList.length > 0 ? page.mediaList.map((item) => item.image) : (page.imageList ?? [])

const formHeading = page.formOverrides?.heading || page.eventSpacesPage.detailFormDefaults?.heading || page.globalFormDefaults?.heading
const formParagraph =
  page.formOverrides?.paragraph || page.eventSpacesPage.detailFormDefaults?.paragraph || page.globalFormDefaults?.paragraph
const formVisualImage = page.formOverrides?.formVisualImage || page.eventSpacesPage.detailFormDefaults?.formVisualImage
const resolvedOverrideFormState =
  page.formOverrides?.overrideFormState ?? page.eventSpacesPage.detailFormDefaults?.overrideFormState
const resolvedFormState = page.formOverrides?.overrideFormState
  ? page.formOverrides?.formState
  : page.eventSpacesPage.detailFormDefaults?.formState
const filteredComponents = (page.components || []).filter((c) => c._type !== 'ContactForm')

const pricingText =
  page.pricing?.pricingVisible && page.pricing?.displayMode === 'fromPrice' && page.pricing?.fromPrice
    ? `${t.pricingFrom} ${page.pricing.fromPrice} ${page.pricing.priceLabel || 'PLN'}`
    : t.pricingQuoteOnly
---

<Layout {...metadata}>
  <Breadcrumbs
    data={[
      { name: page.eventSpacesPage.name, path: page.eventSpacesPage.slug },
      { name: page.name, path: page.slug },
    ]}
  />

  <section
    class="EventSpaceHero max-width"
    data-id={page._id}
    data-name={page.name}
    data-slug={page.slug}
    data-image={mediaItems[0]?.asset?.url || ''}
    data-price={page.pricing?.fromPrice || ''}
  >
    <div class="copy">
      <PortableText value={page.title} heading="h1" class="heading" />
      <p class="description">{page.description}</p>
      <ul class="meta">
        <li><strong>{t.area}:</strong> {page.areaM2} m2</li>
        <li><strong>{t.capacity}:</strong> {page.maxPeople}</li>
        <li>{pricingText}</li>
      </ul>
      <a href={page.googleMaps.googleMapsLink} target="_blank" rel="noopener noreferrer" class="map-link">
        {t.showOnMap}
      </a>
      <div class="actions">
        <Button theme="primary" shade="dark" href={lang === 'pl' ? '#kontakt' : '#contact'}>
          {t.askForQuote}
        </Button>
        <button
          type="button"
          class="inquiry-btn"
          data-label-add={t.addToInquiry}
          data-label-remove={t.removeFromInquiry}
          data-alert-add={t.addedAlert}
          data-alert-remove={t.removedAlert}
        >
          {t.addToInquiry}
        </button>
      </div>
    </div>
    {
      mediaItems.length > 0 && (
        <div class="gallery" data-count={mediaItems.length > 4 ? 4 : mediaItems.length}>
          {mediaItems.slice(0, 4).map((image) => (
            <div class="image-wrapper">
              <Image
                {...image}
                sizes="(max-width: 549px) 100vw, (max-width: 1089px) 48vw, (max-width: 1366px) 32vw, 420px"
              />
            </div>
          ))}
        </div>
      )
    }
  </section>

  <article class="wrapper max-width" id="content">
    <div class="content">
      <ContentPT
        value={page.content}
        additionalComponents={{
          Faq,
          Testimonials,
          Location,
          Checklist,
          BlocksWithImage,
          ImageWithHeadingAndText,
          RowsWithIcons,
          Timeline,
          NextSteps,
        }}
      />
    </div>
  </article>

  {formHeading && (
    <ContactForm
      index={10}
      sectionId={lang === 'pl' ? 'kontakt' : 'contact'}
      heading={formHeading}
      paragraph={formParagraph || []}
      formVisualImage={formVisualImage}
      overrideFormState={resolvedOverrideFormState}
      state={resolvedFormState}
      variant="general"
      showInquiries={false}
      animate={false}
      contextItem={{ type: 'eventSpace', id: page._id, name: page.name }}
    />
  )}
  <Components data={filteredComponents} hasPreviousSections />
</Layout>

<style lang="scss">
  .EventSpaceHero {
    display: grid;
    grid-template-columns: minmax(18rem, 1fr) minmax(20rem, 1.2fr);
    gap: 1.5rem;
    padding: clamp(1.5rem, calc(2vw / 0.48), 2rem) 0 clamp(2rem, calc(3vw / 0.48), 3rem);
  }

  .copy {
    display: grid;
    align-content: start;
    gap: 1rem;
  }

  .description {
    font-size: var(--typography-body-xl, 1.125rem);
    line-height: 1.5;
  }

  .meta {
    display: grid;
    gap: 0.5rem;
    padding: 0;
    margin: 0;
    list-style: none;
    color: var(--primary-700, #600d2a);
  }

  .map-link {
    color: var(--primary-800, #45051c);
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .inquiry-btn {
    min-height: 3rem;
    padding: 0.75rem 1rem;
    border-radius: 999px;
    border: 0.0625rem solid var(--primary-300, #d48d7d);
    background: var(--neutral-100, #faf7f7);
    color: var(--primary-800, #45051c);
    font-weight: 700;
    line-height: 1;
    transition:
      background-color 180ms var(--easing),
      border-color 180ms var(--easing),
      transform 180ms var(--easing);

    &:hover {
      background: var(--neutral-200, #f5f1ec);
      border-color: var(--primary-500, #f67258);
      transform: translateY(-1px);
    }
  }

  .gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .image-wrapper {
    overflow: hidden;
    border-radius: 0.75rem;

    :global(img) {
      width: 100%;
      height: 100%;
      min-height: 12rem;
      object-fit: cover;
    }
  }

  .wrapper {
    padding-bottom: clamp(3rem, calc(4vw / 0.48), 4rem);
  }

  .content {
    max-width: 48rem;
  }

  @media (max-width: 68.0625rem) {
    .EventSpaceHero {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { addToInquiry, isInInquiry, removeFromInquiry } from '@/src/utils/inquiry-store'
  import { dispatchToast } from '@/src/utils/events'
  import { trackEvent } from '@/utils/track-event'

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.EventSpaceHero') as HTMLElement | null
    const inquiryButton = document.querySelector('.inquiry-btn') as HTMLButtonElement | null
    if (!section || !inquiryButton) return

    const itemId = section.dataset.id || ''
    const itemName = section.dataset.name || ''
    const itemImage = section.dataset.image || ''
    const itemSlug = section.dataset.slug || ''
    const itemUrl = itemSlug ? new URL(itemSlug, window.location.origin).toString() : window.location.href
    const priceValue = Number(section.dataset.price || '') || undefined
    const labelAdd = inquiryButton.dataset.labelAdd || ''
    const labelRemove = inquiryButton.dataset.labelRemove || ''
    const alertAdd = inquiryButton.dataset.alertAdd || labelAdd
    const alertRemove = inquiryButton.dataset.alertRemove || labelRemove

    trackEvent({
      ga4: {
        eventName: 'view_item',
        params: {
          currency: 'PLN',
          value: priceValue,
          items: [
            {
              item_id: itemId,
              item_name: itemName,
              price: priceValue,
            },
          ],
        },
      },
      meta: {
        eventName: 'ViewContent',
        contentName: itemName || document.title,
        params: {
          content_ids: itemId ? [itemId] : undefined,
          content_type: 'event_space',
          value: priceValue,
          currency: priceValue ? 'PLN' : undefined,
        },
      },
    })

    const updateButton = () => {
      const inInquiry = itemId ? isInInquiry(itemId) : false
      inquiryButton.textContent = inInquiry ? labelRemove : labelAdd
      inquiryButton.dataset.inInquiry = inInquiry ? 'true' : 'false'
    }

    updateButton()

    inquiryButton.addEventListener('click', () => {
      if (!itemId) return

      if (isInInquiry(itemId)) {
        removeFromInquiry(itemId)
        dispatchToast(alertRemove, 'success')
        updateButton()
        return
      }

      const added = addToInquiry({
        type: 'eventSpace',
        id: itemId,
        name: itemName,
        image: itemImage,
        url: itemUrl,
      })

      if (added) {
        dispatchToast(alertAdd, 'success')
        updateButton()

        trackEvent({
          ga4: {
            eventName: 'add_to_inquiry',
            params: {
              item_id: itemId,
              item_name: itemName,
              item_type: 'eventSpace',
            },
          },
          meta: {
            eventName: 'AddToWishlist',
            contentName: itemName,
            params: {
              content_ids: [itemId],
              content_type: 'event_space',
            },
          },
        })
      }
    })
  })
</script>
